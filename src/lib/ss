/**
 * Validates an external URL to prevent storing links to internal/private
 * resources (defense in depth).
 *
 * This function blocks private IP ranges, IPv6 loopback, cloud metadata
 * endpoints, and various IP obfuscation techniques. Unlike a strict SSRF
 * guard, this validator ALLOWS arbitrary public domains because the feature
 * that uses it ("external link" documents) is meant to store any public URL
 * provided by an admin/coordinator — the server does not perform outbound
 * HTTP requests to these URLs, so there is no direct SSRF risk. The private-
 * range checks exist to prevent accidentally bookmarking internal addresses.
 *
 * IMPORTANT LIMITATION - DNS Rebinding TOCTOU:
 * This validation parses the URL string and checks the hostname. A
 * determined attacker could use DNS rebinding: the hostname resolves to a
 * safe public IP at validation time, but to a private IP at request time.
 * To fully mitigate this, the URL must be resolved to an IP and that IP
 * must be checked at the moment the HTTP request is made (not before).
 * This is a Time-Of-Check-Time-Of-Use (TOCTOU) race condition inherent
 * to hostname-based validation.
 */
export function validateExternalUrl(url: string): boolean {
  try {
    const parsed = new URL(url);

    if (!["http:", "https:"].includes(parsed.protocol)) {
      return false;
    }

    const hostname = parsed.hostname;

    // Block private/link-local/loopback IPv4 ranges (RFC1918 + loopback + link-local).
    const ipv4Private =
      /^(10\.|172\.(1[6-9]|2[0-9]|3[0-1])\.|192\.168\.|127\.|169\.254\.)/;
    if (ipv4Private.test(hostname)) {
      return false;
    }

    // Block IPv6 loopback.
    if (hostname === "::1" || hostname === "[::1]") {
      return false;
    }

    // Block cloud metadata endpoints.
    const metadataIPs = ["169.254.169.254"];
    if (metadataIPs.includes(hostname)) {
      return false;
    }

    // Reject decimal and hex IP obfuscation (e.g. 0x7f000001, 2130706433).
    if (/^\d+$/.test(hostname) || /^0x[0-9a-f]+$/i.test(hostname)) {
      return false;
    }

    // Reject raw IPv6 addresses that look like link-local (fe80::) or unique
    // local (fc00::/fd00::) to avoid internal resource bookmarking.
    if (
      /^fe[89ab][0-9a-f]{0,2}:/.test(hostname) ||
      /^f[cd][0-9a-f]{0,2}:/.test(hostname)
    ) {
      return false;
    }

    // Allow any other public hostname. The allowedDomains list below is kept
    // for documentation/auditing of "known-safe" providers but does NOT
    // restrict the accepted set — external links may point to arbitrary
    // public destinations.
    const allowedDomains = [
      "drive.google.com",
      "docs.google.com",
      "sheets.google.com",
      "sharepoint.com",
      "onedrive.live.com",
      "youtube.com",
      "youtu.be",
      "vimeo.com",
    ];
    // No-op reference to keep the list discoverable for static analysis.
    void allowedDomains;

    return true;
  } catch {
    return false;
  }
}
